  ('editor', false, true, true, true, true, true, true, true, true, true, true, false, false, true, true),
  ('author', true, true, true, true, true, true, true, true, true, true, true, false, false, true, true),
  ('contributor', true, true, true, true, true, true, true, true, false, false, false, false, false, true, true),
  ('commentator', false, false, false, false, false, true, true, true, false, false, false, false, false, true, true),
  ('subscriber', false, false, false, false, false, false, false, false, false, false, false, false, false, false, true);

-- Fonctions stockées :

-- Mettre à jour _modified_at avec le timestamp actuel
CREATE FUNCTION update_modified_at()
RETURNS TRIGGER AS $$
BEGIN
  NEW._modified_at = CURRENT_TIMESTAMP; -- TRUNC(CURRENT_TIMESTAMP, 'microseconds');
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Créer un déclencheur pour chaque table nécessitant la mise à jour de _modified_at
DO $$
DECLARE
  tables TEXT[] := ARRAY['__account', '__article', '__media', '__comment'];
BEGIN
  FOR i IN 1..array_length(tables, 1) LOOP
    EXECUTE format('CREATE TRIGGER update_modified_at_trigger_%I
                    BEFORE UPDATE ON %I
                    FOR EACH ROW
                    EXECUTE FUNCTION update_modified_at()', tables[i], tables[i]);
  END LOOP;
END $$;

-- Réécriture des slugs si contrainte d'unicité violée :
CREATE FUNCTION handle_slug_uniqueness()
RETURNS TRIGGER AS $$
DECLARE
    new_slug VARCHAR(255);
    counter INT := 0;
    is_unique BOOLEAN;
BEGIN
    new_slug := NEW._slug;
    LOOP
        -- Vérifie si le slug existe déjà dans la table
        EXECUTE format('SELECT EXISTS (SELECT 1 FROM %I WHERE _slug = $1)', TG_TABLE_NAME) INTO is_unique USING new_slug;
        EXIT WHEN NOT is_unique;

        -- Si violation d'unicité, ajouter un chiffre et réessayer
        counter := counter + 1;
        new_slug := NEW._slug || '-' || counter;
    END LOOP;

    -- Mettre à jour NEW._slug avec le nouveau slug unique
    NEW._slug := new_slug;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Utilisation d'une boucle pour créer les triggers pour les tables spécifiées
DO $$
DECLARE
    tables TEXT[] := ARRAY['__account', '__article', '__tag'];
    table_name TEXT;
BEGIN
    FOR i IN 1..array_length(tables, 1) LOOP
        table_name := tables[i];
        EXECUTE format('
            CREATE TRIGGER %I_slug_uniqueness
            BEFORE INSERT ON %I
            FOR EACH ROW
            EXECUTE FUNCTION handle_slug_uniqueness();
        ', table_name || '_slug_uniqueness', table_name);
    END LOOP;
END;
$$;

CREATE FUNCTION get_account_list(limit_count INT)
RETURNS TABLE(
  _id INT,
  _username VARCHAR(32),
  _slug VARCHAR(32)
) AS
$$
BEGIN
    RETURN QUERY
    SELECT __account._id, __account._username, __account._slug
    FROM __account
    ORDER BY __account._username ASC
    LIMIT limit_count;
END;
$$
LANGUAGE plpgsql;

CREATE FUNCTION get_person_list(limit_count INT)
RETURNS TABLE (
  _id INT,
  _prefix VARCHAR(32),
  _given_name VARCHAR(32),
  _additional_name VARCHAR(32),
  _family_name VARCHAR(32),
  _suffix VARCHAR(32),
  _nickname VARCHAR(32)
) AS
$$
BEGIN
    RETURN QUERY
    SELECT
      __person._id,
      __person._prefix,
      __person._given_name,
      __person._additional_name,
      __person._family_name,
      __person._suffix,
      __person._nickname
    FROM __person
    ORDER BY __person._id ASC
    LIMIT limit_count;
END;
$$
LANGUAGE plpgsql;

CREATE FUNCTION get_article_list(limit_count INT)
RETURNS TABLE(
  _name VARCHAR(255),
  _slug VARCHAR(255)
) AS
$$
BEGIN
    RETURN QUERY
    SELECT __article._name, __article._slug
    FROM __article
    ORDER BY __article._name ASC
    LIMIT limit_count;
END;
$$
LANGUAGE plpgsql;

CREATE FUNCTION get_tag_list(limit_count INT)
RETURNS TABLE(
  _id INT,
  _name VARCHAR(64),
  _slug VARCHAR(64)
) AS
$$
BEGIN
    RETURN QUERY
    SELECT __tag._id, __tag._name, __tag._slug
    FROM __tag
    ORDER BY __tag._name ASC
    LIMIT limit_count;
END;
$$
LANGUAGE plpgsql;

CREATE FUNCTION get_place_list(limit_count INT)
RETURNS TABLE(
  _id INT,
  _name VARCHAR(60)
) AS
$$
BEGIN
    RETURN QUERY
    SELECT __place._id, __place._name
    FROM __place
    ORDER BY __place._id ASC
    LIMIT limit_count;
END;
$$
LANGUAGE plpgsql;

CREATE FUNCTION get_articles_by_tag(tag_slug text, limit_count integer)
RETURNS TABLE (
    _id integer,
    _name VARCHAR(255),
    _alternative_headline VARCHAR(255),
    _slug VARCHAR(255),
    _created_at timestamp,
    _modified_at timestamp,
    _type VARCHAR(30),
    _description VARCHAR(1000),
    _author_id integer,
    _status SMALLINT,
    _is_readable boolean,
    _account jsonb,
    _author jsonb
)
AS $$
BEGIN
    RETURN QUERY
    SELECT
        a._id,
        a._name,
        a._alternative_headline,
        a._slug,
        a._created_at,
        a._modified_at,
        a._type,
        a._description,
        a._author_id,
        a._status,
        a._is_readable,
        jsonb_build_object(
            '_username', ac._username,
            '_display_name', ac._display_name
        ) AS _account,
        jsonb_build_object(
            '_given_name', p._given_name,
            '_additional_name', p._additional_name,
            '_family_name', p._family_name,
            '_usual_name', p._usual_name,
            '_nickname', p._nickname,
            '_prefix', p._prefix,
            '_suffix', p._suffix,
            '_url', p._url
        ) AS _author
    FROM
        __article a
    LEFT JOIN
        __account ac ON a._author_id = ac._id
    LEFT JOIN
        __person p ON ac._person_id = p._id
    LEFT JOIN
        __tag_to_article ta ON a._id = ta._article_id
    LEFT JOIN
        __tag t ON ta._tag_id = t._id
    WHERE
        t._slug = tag_slug
    ORDER BY
        a._created_at DESC
    LIMIT
        limit_count;
END;
$$ LANGUAGE plpgsql;

