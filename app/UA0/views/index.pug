extends patternLayout

block variables
  - const documentType = 'index'
  -
    const data = {
      name: 'Mon Planning',
      title: 'Mon planning à l\'UA0',
      description: 'Anticiper mes horraires postés dans le temps.',
      themeColor: '#2994ff',
      ccc: 'Au fil de l\'O'
    }

block main
  article
    header.header.no-print(role='banner')
      .wrapper
        h1.main-heading!= data.name
    .main-content
      .wrapper
        .tabs
          .tab-list(role='tablist' aria-label='Entertainment')
            button#tabsummary-0.tab-summary(type='button' role='tab' aria-controls='tab-panel-0' aria-selected='true')
              svg.icon(focusable='false')
                use(href='./sprites/util.svg#calendar_month')
              span Planning
            button#tabsummary-1.tab-summary(type='button' role='tab' aria-controls='tab-panel-1' aria-selected='false')
              svg.icon(focusable='false')
                use(href='./sprites/util.svg#bar_chart')
              span Statistiques
            button#tabsummary-2.tab-summary(type='button' role='tab' aria-controls='tab-panel-2' aria-selected='false')
              svg.icon(focusable='false')
                use(href='./sprites/util.svg#tune')
              span Configuration
          include includes/pannel1
          include includes/pannel2
          include includes/pannel3
